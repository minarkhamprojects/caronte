# ─── Caronte ───
# Copia este archivo a .env y completa los valores.

# Token de autenticación (cámbialo por uno seguro)
CARONTE_TOKEN=pon-aqui-tu-token-seguro

# Puerto local (default 8788)
CARONTE_PORT=8788

# Nombre del host donde corre este servidor (local)
CARONTE_LOCAL_NAME=server

# Hosts remotos alcanzables por SSH. Array JSON.
# Ejemplo con un laptop:
# CARONTE_REMOTE_HOSTS=[{"name":"laptop","ssh":"usuario@ip-del-laptop"}]
CARONTE_REMOTE_HOSTS=[]
